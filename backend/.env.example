# ===============================
# Backend (CampusWay)
# ===============================
# Test environment (optional but recommended for stable automated tests)
# TEST_MONGO_URI=mongodb://127.0.0.1:27017
# TEST_MONGO_DB=campusway_test
# MONGOMS_DOWNLOAD_DIR=/absolute/path/to/mongodb-binaries-cache

# Required (all environments)
PORT=5000
MONGODB_URI=mongodb://localhost:27017/campusway
MONGO_URI=mongodb://localhost:27017/campusway
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret
# 64-char hex string (32 bytes) for AES-256-GCM encryption of provider credentials
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
FRONTEND_URL=http://localhost:5175
ADMIN_ORIGIN=http://localhost:5175

# Required in production
# NODE_ENV=production
# FRONTEND_URL=https://your-frontend-domain.com
# ADMIN_ORIGIN=https://your-admin-domain.com
# CORS_ORIGIN=https://your-frontend-domain.com,https://your-admin-domain.com

# Auth/session tuning
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ACCESS_TOKEN_TTL_MINUTES=20
REFRESH_TOKEN_TTL_DAYS=7

# API routing/admin path
ADMIN_SECRET_PATH=campusway-secure-admin
CORS_ORIGIN=http://localhost:5173,http://localhost:5175
NODE_ENV=development

# Bootstrap/default setup
SENDGRID_API_KEY=
ADMIN_EMAIL=admin@campusway.example
ALLOW_DEFAULT_SETUP=true
ALLOW_TEST_OTP=true
TEST_OTP_CODE=123456
APP_DOMAIN=http://localhost:5173

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@campusway.local

# Optional AWS/S3 storage
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=

# Optional payment webhook secrets
SSLCOMMERZ_STORE_PASSWORD=
PAYMENT_WEBHOOK_SECRET=

# Optional AI integrations (backend only)
OPENAI_API_KEY=

# Optional Firebase admin integration
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Optional Firebase App Check enforcement (recommended for public write endpoints)
APP_CHECK_ENFORCED=false

# Optional Azure monitoring / cloud readiness
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Azure App Service / Key Vault reference examples (cloud-side only)
# JWT_SECRET=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/campusway-jwt-secret/<version>)
# JWT_REFRESH_SECRET=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/campusway-jwt-refresh-secret/<version>)
# ENCRYPTION_KEY=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/campusway-encryption-key/<version>)
# MONGODB_URI=@Microsoft.KeyVault(SecretUri=https://<vault>.vault.azure.net/secrets/campusway-mongodb-uri/<version>)

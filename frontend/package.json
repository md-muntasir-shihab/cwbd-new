{
    "name": "campusway-frontend",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "e2e": "playwright test",
        "e2e:headed": "playwright test --headed",
        "e2e:smoke": "node ./scripts/run-e2e-smoke.mjs",
        "e2e:next-smoke": "node ./scripts/run-next-smoke.mjs",
        "e2e:visual-baseline": "node ./scripts/run-e2e-smoke.mjs e2e/visual-baseline.spec.ts",
        "e2e:role-full-qa": "node ./scripts/role-full-qa-run.mjs",
        "e2e:prepare": "npm --prefix ../backend run e2e:prepare",
        "e2e:restore": "npm --prefix ../backend run e2e:restore",
        "mcp:smoke": "node ./scripts/mcp-smoke.mjs",
        "mcp:full-sweep": "node ./scripts/playwright-full-sweep.mjs",
        "perf:autosave": "node ./scripts/perf-autosave.mjs",
        "perf:lighthouse:landing": "node ./scripts/lighthouse-exam-landing.mjs"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.90.21",
        "@types/dompurify": "^3.0.5",
        "axios": "^1.7.9",
        "browser-image-compression": "^2.0.2",
        "chart.js": "^4.4.7",
        "date-fns": "^4.1.0",
        "dayjs": "^1.11.19",
        "dompurify": "^3.3.2",
        "firebase": "^12.10.0",
        "framer-motion": "^12.34.3",
        "katex": "^0.16.33",
        "lucide-react": "^0.469.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.0.0",
        "react-chartjs-2": "^5.3.0",
        "react-dom": "^19.0.0",
        "react-helmet-async": "^3.0.0",
        "react-hot-toast": "^2.6.0",
        "react-is": "^19.2.4",
        "react-katex": "^3.1.0",
        "react-markdown": "^10.1.0",
        "react-quill": "^2.0.0",
        "react-router-dom": "^7.1.0",
        "recharts": "^3.8.0",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0",
        "screenfull": "^6.0.2",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@playwright/test": "^1.52.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "eslint": "^9.17.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "globals": "^15.14.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.18.2",
        "vite": "^6.0.5"
    }
}

# ===============================
# Frontend (Vite)
# ===============================
# Required for production build
VITE_API_BASE_URL=http://localhost:5003/api

# Optional (development only)
# If unset, Vite app calls VITE_API_BASE_URL directly.
VITE_API_PROXY_TARGET=http://localhost:5003

# Backend admin API path segment (must match backend ADMIN_SECRET_PATH)
VITE_ADMIN_PATH=campusway-secure-admin

# App metadata
VITE_APP_NAME=CampusWay
VITE_ENABLE_OAUTH=false

# Mock API mode (set to 'true' to use mock data instead of real backend)
VITE_USE_MOCK_API=false

# Optional Firebase client config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=
